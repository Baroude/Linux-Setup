  "kde_install_config": {
    "method": "lookandfeel",
    "repo": "https://github.com/rose-pine/kde"
  },
  "kvantum_config": {
    "enabled": false
  },
  "gtk_install_config": {
    "method": "gtk_repo",
    "repo": "https://github.com/rose-pine/gtk"
  },
  "bat_theme_config": {
    "repo": "https://github.com/rose-pine/bat",
    "file_pattern": "rose-pine-${flavor}.tmTheme",
    "files_by_flavor": {
      "main": "rose-pine.tmTheme",
      "moon": "rose-pine-moon.tmTheme",
      "dawn": "rose-pine-dawn.tmTheme"
    }
  },
  "btop_theme_config": {
    "repo": "https://github.com/rose-pine/btop",
    "file_pattern": "rose-pine-${flavor}.theme",
    "files_by_flavor": {
      "main": "rose-pine.theme",
      "moon": "rose-pine-moon.theme",
      "dawn": "rose-pine-dawn.theme"
    }
  },
  "firefox_config": {
    "method": "github_xpi",
    "repo": "rose-pine/firefox",
    "file_pattern": "rose-pine-${flavor}.xpi"
  },
  "derived_patterns": {
    "nvim_plugin": "rose-pine",
    "nvim_flavor": "${flavor}",
    "kde_scheme": "RosePine${FlavorTitle}",
    "kde_lookandfeel": "com.github.rose-pine.kde.${flavor}",
    "kscreenlock_theme": "com.github.rose-pine.kde.${flavor}",
    "kvantum_theme": "RosePine",
    "gtk_theme": "rose-pine-${flavor}",
    "gtk_cursor_theme": "rose-pine-${flavor}-cursors",
    "starship_palette": "rosepine_${flavor}",
    "bat_theme": "rose-pine-${flavor}",
    "btop_theme": "rose-pine-${flavor}",
    "delta_theme": "rose-pine-${flavor}"
  },
  "widget_slot_map": {
    "org.kde.plasma.pager": "lavender",
    "org.kde.plasma.windowtitle": "subtext0",
    "com.github.antroids.application-title-bar": "pink",
    "org.kde.plasma.digitalclock": "accent",
    "org.kde.plasma.weather": "blue",
    "org.kde.plasma.appmenu": "green",
    "org.kde.plasma.mediacontroller": "teal",
    "org.kde.plasma.systemmonitor": "peach",
    "org.kde.plasma.systemtray": "sky",
    "org.kde.plasma.lock_logout": "red"
  },
  "sddm_config": {
    "method": "git_sddm",
    "repo": "https://github.com/lwndhrst/sddm-rose-pine",
    "theme_subdir": ".",
    "target_name": "sddm-rose-pine"
  },
  "grub_config": {
    "method": "git_grub",
    "repo": "https://github.com/rose-pine/grub",
    "theme_subdir": ".",
    "target_name": "rose-pine-grub"
  }
}
