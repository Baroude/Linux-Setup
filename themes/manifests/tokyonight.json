  "kde_install_config": {
    "method": "lookandfeel",
    "repo": "https://github.com/Drigax/tokyo-night-kde"
  },
  "kvantum_config": {
    "enabled": true,
    "method": "kvantum_repo",
    "repo": "https://github.com/Drigax/tokyo-night-kde"
  },
  "gtk_install_config": {
    "method": "gtk_repo",
    "repo": "https://github.com/Fausto-Korpsvart/Tokyonight-GTK-Theme"
  },
  "bat_theme_config": {
    "repo": "https://github.com/folke/tokyonight.nvim",
    "file_pattern": "tokyonight_${flavor}.tmTheme"
  },
  "btop_theme_config": {
    "repo": "https://github.com/nicknisi/dotfiles",
    "file_pattern": "tokyo-night.theme"
  },
  "firefox_config": {
    "method": "none"
  },
  "derived_patterns": {
    "nvim_plugin": "tokyonight",
    "nvim_flavor": "${flavor}",
    "kde_scheme": "TokyoNight${FlavorTitle}",
    "kde_lookandfeel": "com.github.drigax.tokyonight.${flavor}",
    "kscreenlock_theme": "com.github.drigax.tokyonight.${flavor}",
    "kvantum_theme": "TokyoNight-${FlavorTitle}",
    "gtk_theme": "Tokyonight-Dark-BL",
    "gtk_cursor_theme": "Tokyonight-Dark-Cursors",
    "starship_palette": "tokyonight_${flavor}",
    "bat_theme": "tokyonight_${flavor}",
    "btop_theme": "tokyo-night",
    "delta_theme": "tokyonight_${flavor}"
  },
  "widget_slot_map": {
    "org.kde.plasma.pager": "lavender",
    "org.kde.plasma.windowtitle": "subtext0",
    "com.github.antroids.application-title-bar": "pink",
    "org.kde.plasma.digitalclock": "accent",
